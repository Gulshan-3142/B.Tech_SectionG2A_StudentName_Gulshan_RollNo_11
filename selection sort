#include<stdio.h>
int main(){
    int arr[10],n;
    
    //take array size
    printf("enter size of array: ");
    scanf("%d",&n);

    //take input
    printf("\nenter value: \n");
    for(int i=0; i<n; i++){
        scanf("%d",&arr[i]);
    }

    //sorting 

    for(int i=0; i<n-1; i++){
       int indexNo=i;
       int a = arr[i];
       for(int j=i+1; j<n; j++){

        if(a > arr[j]){
            indexNo=j;
            a=arr[j];
        }
       }

       int temp = arr[i];
       arr[i] = arr[indexNo];
       arr[indexNo] = temp;
    }

   // print output 
   for(int i=0; i<n; i++){
    printf("%d ",arr[i]);
   }

   return 0;
}
